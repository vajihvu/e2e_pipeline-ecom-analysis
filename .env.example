# .env.example
# -------------
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ─── PostgreSQL ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ─── Airflow ──────────────────────────────────
# Absolute path to the project root on your machine.
# Used by the DAG to locate scripts/ and data/.
# Example (Mac/Linux): /home/yourname/projects/ecommerce-pipeline
# Example (Windows):   C:/Users/yourname/projects/ecommerce-pipeline
PIPELINE_BASE_DIR=/absolute/path/to/ecommerce-pipeline
